            "type": "TEXT",
            "data": "\u001b[1m\u001b[34mcolumnasActiva\u001b[0m: \u001b[1m\u001b[32mArray[String]\u001b[0m \u003d Array(ACTIVA_H1, ACTIVA_H2, ACTIVA_H3, ACTIVA_H4, ACTIVA_H5, ACTIVA_H6, ACTIVA_H7, ACTIVA_H8, ACTIVA_H9, ACTIVA_H10, ACTIVA_H11, ACTIVA_H12, ACTIVA_H13, ACTIVA_H14, ACTIVA_H15, ACTIVA_H16, ACTIVA_H17, ACTIVA_H18, ACTIVA_H19, ACTIVA_H20, ACTIVA_H21, ACTIVA_H22, ACTIVA_H23, ACTIVA_H24)\n\u001b[1m\u001b[34massembler\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.ml.feature.VectorAssembler\u001b[0m \u003d VectorAssembler: uid\u003dvecAssembler_d4e005c5b669, handleInvalid\u003derror, numInputCols\u003d24\n\u001b[1m\u001b[34mscaler\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.ml.feature.StandardScaler\u001b[0m \u003d stdScal_4c6e2f2cac92\n\u001b[1m\u001b[34mlabelIndexer\u001b[0m: \u001b[1m\u001b[32morg.apache.spark.ml.feature.StringIndexer\u001b[0m \u003d strIdx_e1e038f7ccbe\n"
